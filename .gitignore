#-── SECRETS — NEVER commit these ────────────────────────────────────────
*.pem                   # SSL private keys
*.key                   # private keys of any kind
*.p12                   # PKCS12 keystores
.env                    # environment variable files with secrets
.env.*                  # .env.production, .env.local, etc
secrets/                # any directory named secrets
*_credentials*          # AWS/Azure credential files
*credentials.json       # GCP credentials
 
# ── TERRAFORM ────────────────────────────────────────────────────────────
*.tfstate               # Terraform state (use remote backend instead)
*.tfstate.backup        # state backups
.terraform/             # provider plugins (large, regenerated by terraform init)
terraform.tfvars        # often contains real account IDs and secrets
*.tfvars.json           # same
.terraform.lock.hcl     # can be committed but often project-specific
 
# ── ANSIBLE ──────────────────────────────────────────────────────────────
vault_password_file     # plaintext vault password file
*.vault.yml             # plaintext vault (only commit encrypted vault files)
 
# ── OS & EDITOR JUNK ─────────────────────────────────────────────────────
.DS_Store               # macOS
Thumbs.db               # Windows
.idea/                  # IntelliJ
.vscode/settings.json   # VSCode personal settings (not extensions or config)
*.swp                   # vim swap files
*.swo
 
# ── SCRIPT OUTPUTS ────────────────────────────────────────────────────────
*.log                   # log files
*.tmp
/tmp/
 
# ── PYTHON (if you write helper scripts) ──────────────────────────────────
__pycache__/
*.pyc
.venv/
venv/
